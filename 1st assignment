def sum_recursive(arr, index):
    if index == len(arr):
        return 0
    return arr[index] + sum_recursive(arr, index + 1)


n = int(input())
arr = list(map(int, input().split()))

total = sum_recursive(arr, 0)
average = total / n

print(average)


