def is_prime(n, divisor=2):
    if n < 2:
        return False
    if divisor * divisor > n:
        return True
    if n % divisor == 0:
        return False
    return is_prime(n, divisor + 1)


n = int(input())

if is_prime(n):
    print("Prime")
else:
    print("Composite")

